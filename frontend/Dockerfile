FROM node:22-bookworm-slim AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable

FROM base AS build
COPY . /usr/src/app
WORKDIR /usr/src/app
# Build-time args — NEXT_PUBLIC_* vars are inlined into JS bundle at compile time
ARG NEXT_PUBLIC_API_URL=/api/v1
ARG NEXT_PUBLIC_SENTRY_DISABLED=true
ENV BUILD_STANDALONE=true
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_SENTRY_DISABLED=$NEXT_PUBLIC_SENTRY_DISABLED
RUN --mount=type=cache,id=pnpm,target=/pnpm/store CI=true pnpm install --frozen-lockfile
RUN pnpm --filter frontend build

FROM base AS runner
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nodejs
WORKDIR /usr/src/app
# Copy only the standalone output — no source, no devDeps, no monorepo workspace
COPY --from=build --chown=nodejs:nodejs /usr/src/app/frontend/.next/standalone ./
COPY --from=build --chown=nodejs:nodejs /usr/src/app/frontend/.next/static ./frontend/.next/static
COPY --from=build --chown=nodejs:nodejs /usr/src/app/frontend/public ./frontend/public
USER nodejs
EXPOSE 8080
ENV PORT=8080
ENV HOSTNAME="0.0.0.0"
ENV NODE_ENV=production
# server.js is the standalone entrypoint generated by Next.js — no pnpm, no workspace
WORKDIR /usr/src/app/frontend
CMD ["node", "server.js"]
