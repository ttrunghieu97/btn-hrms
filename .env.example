# ==============================================================================
# BTN HRMS — Root Environment Configuration Example
# ==============================================================================

# 1. System & Timezone Settings
TZ=Asia/Ho_Chi_Minh
APP_TIMEZONE=Asia/Ho_Chi_Minh
NEXT_PUBLIC_APP_TIMEZONE=Asia/Ho_Chi_Minh

# Host IP Configuration (Single Source of Truth for development)
HOST_IP=127.0.0.1

# 2. Database Configuration (PostgreSQL)
POSTGRES_USER=hrms
POSTGRES_DB=hrms
POSTGRES_PASSWORD=your_postgres_password_here

# 3. Object Storage Configuration (MinIO S3)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password_here

# 4. Security & Cryptography Keys
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
PII_ENCRYPTION_KEY=your_pii_encryption_key_here
DEFAULT_EMPLOYEE_PASSWORD=BtnHrms2025!@#

# 5. Frontend & CORS Routing Configuration
FRONTEND_URL=http://${HOST_IP}:8080

# 6. Compose Deployment Configuration
APP_URL=https://btn.hieutt.id.vn
AUTH_JWT_SECRET=your_jwt_secret_here
AUTH_JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
AUTH_DEFAULT_PASSWORD=BtnHrms2025!@#
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here
