# Force LF for shell scripts (Windows Git defaults to CRLF — breaks container entrypoints)
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# Keep Docker-related files with LF as well (can cause issues in Linux containers)
Dockerfile text eol=lf
Dockerfile.* text eol=lf
*.dockerfile text eol=lf

# Normalize everything else to LF on check-in
* text=auto eol=lf
