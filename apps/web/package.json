  },
  "scripts": {
    "dev": "node --max-old-space-size=4096 node_modules/next/dist/bin/next dev --hostname 0.0.0.0 --port 8080",
    "build": "node --max-old-space-size=4096 node_modules/next/dist/bin/next build",
    "start": "next start --hostname 0.0.0.0 --port 8080",
    "lint:arch": "eslint -c eslint.arch.config.mjs \"src/**/*.{ts,tsx}\"",
    "client:generate": "orval --config orval.config.ts && node ./scripts/postprocess-orval.cjs && node ./scripts/generate-error-contract-catalog.cjs && node ./scripts/verify-generated-client.cjs",
    "client:verify": "node ./scripts/verify-generated-client.cjs && pnpm error-contracts:verify",
    "error-contracts:generate": "node ./scripts/generate-error-contract-catalog.cjs",
    "error-contracts:verify": "node ./scripts/generate-error-contract-catalog.cjs --check",
    "typecheck": "pnpm error-contracts:verify && tsc --noEmit",
    "test": "jest --runInBand",
    "lint": "pnpm error-contracts:verify && eslint --config eslint.arch.config.mjs \"src/**/*.{ts,tsx}\" --max-warnings 1227",
    "depcruise": "depcruise --validate .dependency-cruiser.cjs src",
    "ci:verify": "pnpm typecheck && pnpm lint && pnpm depcruise && pnpm build",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
