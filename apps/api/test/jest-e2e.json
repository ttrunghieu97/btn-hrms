{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "setupFiles": ["<rootDir>/setup-env.js"],
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", {
      "diagnostics": false
    }]
  },
  "transformIgnorePatterns": [],
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/../src/$1"
  }
}
