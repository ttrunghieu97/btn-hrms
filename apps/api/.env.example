# Runtime & Server
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
TRUST_PROXY=1
APP_URL=http://localhost:3001

# Bootstrap flags
BOOT_VERIFY_DB=true
BOOT_ENABLE_SWAGGER=false
BOOT_ENABLE_OTEL=false
BOOT_ENABLE_VAULT=false
BOOT_ENABLE_REDIS_EVENT_BUS=false

# Database (PostgreSQL)
DATABASE_URL=postgres://hrms:your_postgres_password_here@127.0.0.1:5432/hrms
DATABASE_DIRECT_URL=postgres://hrms:your_postgres_password_here@127.0.0.1:5432/hrms

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Storage (MinIO / S3)
STORAGE_BACKEND=s3
STORAGE_BUCKET=btn-hrms
STORAGE_S3_URL=http://127.0.0.1:9000
STORAGE_S3_ENDPOINT=http://127.0.0.1:9000
STORAGE_S3_PUBLIC_ENDPOINT=http://127.0.0.1:9000
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=minioadmin
STORAGE_S3_SECRET_KEY=your_minio_password_here
STORAGE_SIGNED_URLS=false
STORAGE_SIGNED_URL_TTL_SEC=300
STORAGE_S3_FORCE_PATH_STYLE=true

# Auth
AUTH_JWT_SECRET=your_jwt_secret_here
AUTH_JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
DEFAULT_EMPLOYEE_PASSWORD=BtnHrms2025!@#
ACCESS_COOKIE_SECURE=false
REFRESH_COOKIE_SECURE=false

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_SERVICE_NAME=btn-hrms-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

ALLOW_DB_RESET=false
ALLOW_REMOTE_DB_RESET=false
SEED_PASSWORD=123456
